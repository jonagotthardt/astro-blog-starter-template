---
import Layout from "../layouts/BlogPost.astro";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<html lang="en">
  <head>
    <BaseHead title="Jona Gotthardt • Plugin Developer" description={SITE_DESCRIPTION} />
    <style is:global>
      body {
        margin: 0;
        font-family: 'Poppins', sans-serif;
        color: #e0e0e0;
        overflow-x: hidden;
        background: linear-gradient(120deg, #0f0c29, #302b63, #24243e);
      }

      .particles {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 0;
      }

      h1, h2 {
        color: #00bcd4;
        text-shadow: 0 0 15px rgba(0,188,212,0.5);
      }

      p {
        color: #f0f0f0;
        font-size: 1.1rem;
      }

      header.hero {
        text-align: center;
        padding: 90px 20px 40px;
      }

      h1 {
        font-size: 3.2rem;
        margin: 0;
        background: linear-gradient(90deg, #00ff9c, #00bcd4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      p.subtitle {
        font-size: 1.2rem;
        opacity: 0.85;
        margin-top: 12px;
      }

      section.about {
        background: rgba(0, 0, 0, 0.4);
        border-radius: 12px;
        padding: 30px;
        margin: 50px auto;
        max-width: 900px;
        text-align: center;
        line-height: 1.6;
        opacity: 0;
        transform: translateY(50px);
        transition: all 0.6s ease;
      }

      section.about.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .viewall {
        text-align: center;
        margin-top: 40px;
      }

      .viewall a {
        color: #00bcd4;
        font-weight: 600;
        text-decoration: none;
        transition: color 0.3s;
      }

      .viewall a:hover {
        color: #00e5ff;
      }

      footer {
        margin-top: 70px;
      }
    </style>
  </head>

  <body>
    <div class="particles" id="particles"></div>
    <Header />

    <header class="hero">
      <h1>Jona Gotthardt</h1>
      <p class="subtitle">Plugin Developer • Creator • Innovator</p>
    </header>

    <section class="about">
      <p>
        Hey! I’m <strong>Jona Gotthardt</strong>, a passionate developer who builds custom Minecraft
        plugins and creative systems designed for both <strong>Java</strong> and <strong>Bedrock</strong>.
      </p>
      <p>
        My goal is to make plugins that are <strong>lightweight</strong>, <strong>highly optimized</strong>,
        and fun to use — always with quality, balance, and creativity in mind.
      </p>
    </section>

    <section class="about">
      <h2>What’s Next</h2>
      <p>
        I’m working on new creative ideas for 1.21.9+ — including utility packs, server enhancements,
        and unique gameplay mechanics that push Minecraft’s limits even further.
      </p>
      <p>
        Follow along to see what’s coming next. Every project is built to inspire creativity and fun.
      </p>
      <div class="viewall">
        <a href="/plugins">→ View all plugins</a>
      </div>
    </section>

    <Footer />

    <script>
      // Canvas particle animation (same as BlogPost layout)
      const canvas = document.createElement('canvas');
      document.getElementById('particles').appendChild(canvas);
      const ctx = canvas.getContext('2d');
      let w = canvas.width = window.innerWidth;
      let h = canvas.height = window.innerHeight;

      let particles = [];
      for (let i = 0; i < 100; i++) {
        particles.push({ x: Math.random() * w, y: Math.random() * h, r: Math.random() * 3 + 1, d: Math.random() * 1 });
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = 'rgba(0,255,255,0.7)';
        ctx.beginPath();
        for (let i = 0; i < particles.length; i++) {
          let p = particles[i];
          ctx.moveTo(p.x, p.y);
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2, true);
        }
        ctx.fill();
        update();
      }

      function update() {
        for (let i = 0; i < particles.length; i++) {
          let p = particles[i];
          p.y += 0.2;
          if (p.y > h) { p.y = 0; p.x = Math.random() * w; }
        }
      }

      setInterval(draw, 30);
      window.addEventListener('resize', () => { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; });
    </script>

    <script>
      // Fade-in animation on scroll
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) entry.target.classList.add('visible');
        });
      }, { threshold: 0.2 });

      document.querySelectorAll('section.about').forEach(sec => observer.observe(sec));
    </script>
  </body>
</html>
